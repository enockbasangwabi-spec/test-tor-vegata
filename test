<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simulatore TEST ITA L2 - Tor Vergata</title>
    <style>
        :root {
            --primary: #1e3a8a;
            --secondary: #0284c7;
            --success: #22c55e;
            --danger: #ef4444;
            --bg: #f8fafc;
            --text: #1e293b;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 0;
        }
        header {
            background-color: var(--primary);
            color: white;
            padding: 20px;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }
        .container {
            max-width: 1000px;
            margin: 30px auto;
            padding: 20px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
        }
        .timer-box {
            font-size: 24px;
            font-weight: bold;
            color: var(--danger);
            background: #fee2e2;
            padding: 10px 20px;
            border-radius: 8px;
            display: inline-block;
            margin-top: 10px;
        }
        .section-title {
            background: var(--secondary);
            color: white;
            padding: 12px;
            border-radius: 6px;
            margin-top: 30px;
        }
        .question-card {
            margin: 25px 0;
            padding: 20px;
            border-left: 5px solid var(--secondary);
            background: #f1f5f9;
            border-radius: 0 8px 8px 0;
        }
        .options {
            margin-top: 15px;
        }
        .option-label {
            display: block;
            margin: 10px 0;
            padding: 10px;
            background: white;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .option-label:hover {
            background: #e2e8f0;
        }
        input[type="radio"] {
            margin-right: 10px;
        }
        .btn-submit {
            display: block;
            width: 100%;
            padding: 15px;
            background: var(--success);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 40px;
        }
        .btn-submit:hover {
            background: #16a34a;
        }
        .audio-simulation, .text-passage {
            background: #fff;
            border: 1px dashed #94a3b8;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 15px;
            font-style: italic;
        }
        #result {
            display: none;
            padding: 30px;
            background: #ecfdf5;
            border: 2px solid var(--success);
            border-radius: 12px;
            margin-top: 30px;
            text-align: center;
        }
    </style>
</head>
<body>

<header>
    <h1>SIMULATORE UFFICIALE CISIA - TEST ITA L2</h1>
    <p>Università degli Studi di Roma Tor Vergata - Sessione Extra-UE</p>
    <div class="timer-box">Tempo Rimasto: <span id="time">72:00</span></div>
</header>

<div class="container" id="quiz-container">
    <p><strong>Struttura del Test:</strong> 72 Domande (30 Ascolto, 25 Lettura, 17 Strutture della lingua). <br>
    <em>Punteggio: +1 Risposta esatta | 0 Non data | -0.25 Risposta errata.</em></p>

    <form id="quiz-form">
        <!-- SEZIONE 1: ASCOLTO (Échantillon de questions représentatives sur 30) -->
        <h2 class="section-title">Sezione 1: ASCOLTO (30 Domande)</h2>
        <div class="audio-simulation">
            <strong>Traccia Audio 1 (Simulata):</strong> "Benvenuti all'Università di Roma Tor Vergata. Gli studenti stranieri devono presentare il permesso di soggiorno all'ufficio di Segreteria Studenti entro il 30 novembre, pena la sospensione della carriera universitaria..."
        </div>

        <!-- Q1 -->
        <div class="question-card">
            <p><strong>1. Qual è la scadenza per presentare il permesso di soggiorno in segreteria?</strong></p>
            <div class="options">
                <label class="option-label"><input type="radio" name="q1" value="A"> A) Entro l'inizio delle lezioni.</label>
                <label class="option-label"><input type="radio" name="q1" value="B"> B) Entro il 30 novembre.</label>
                <label class="option-label"><input type="radio" name="q1" value="C"> C) Entro la fine dell'anno accademico.</label>
                <label class="option-label"><input type="radio" name="q1" value="D"> D) Non c'è una scadenza ufficiale.</label>
            </div>
        </div>

        <!-- Altre domande di ascolto clonate per la struttura a 72 -->
        <!-- Per ragioni di spazio nel codice, i blocchi ripetono la struttura reale del CISIA -->
        <div class="audio-simulation">
            <strong>Traccia Audio 2 (Simulata):</strong> Dialogue tra due studenti sulla preparazione dell'esame di Diritto Commerciale in biblioteca.
        </div>
        <div class="question-card">
            <p><strong>2. Perché lo studente è preoccupato per l'esame?</strong></p>
            <div class="options">
                <label class="option-label"><input type="radio" name="q2" value="A"> A) Perché la biblioteca è chiusa.</label>
                <label class="option-label"><input type="radio" name="q2" value="B"> B) Perché il programma di studio è molto lungo e complesso.</label>
                <label class="option-label"><input type="radio" name="q2" value="C"> C) Perché ha perso i suoi appunti di lezione.</label>
                <label class="option-label"><input type="radio" name="q2" value="D"> D) Perché il professore ha rimandato l'appello.</label>
            </div>
        </div>

        <!-- SEZIONE 2: LETTURA -->
        <h2 class="section-title">Sezione 2: LETTURA (25 Domande)</h2>
        <div class="text-passage">
            <strong>Testo 1:</strong> "La trasformazione digitale ha modificato radicalmente le abitudini dei consumatori globali. Nei mercati emergenti, le applicazioni mobili rappresentano non solo uno strumento di commercio, ma il principale vettore di inclusione finanziaria per le piccole imprese locali..."
        </div>
        <div class="question-card">
            <p><strong>31. Secondo il testo, che ruolo hanno le applicazioni mobili nei mercati emergenti?</strong></p>
            <div class="options">
                <label class="option-label"><input type="radio" name="q31" value="A"> A) Sostituiscono completamente i negozi fisici.</label>
                <label class="option-label"><input type="radio" name="q31" value="B"> B) Favoriscono l'inclusione finanziaria delle piccole imprese.</label>
                <label class="option-label"><input type="radio" name="q31" value="C"> C) Riducono la sicurezza dei pagamenti digitali.</label>
                <label class="option-label"><input type="radio" name="q31" value="D"> D) Sono utilizzate esclusivamente dalle grandi multinazionali.</label>
            </div>
        </div>

        <!-- SEZIONE 3: STRUTTURE DELLA LINGUA -->
        <h2 class="section-title">Sezione 3: STRUTTURE DELLA LINGUA (17 Domande)</h2>
        
        <div class="question-card">
            <p><strong>56. Completa la frase: "Penso che il professore ___________ già i risultati dell'esame sul portale."</strong></p>
            <div class="options">
                <label class="option-label"><input type="radio" name="q56" value="A"> A) ha pubblicato</label>
                <label class="option-label"><input type="radio" name="q56" value="B"> B) abbia pubblicato</label>
                <label class="option-label"><input type="radio" name="q56" value="C"> C) pubblicasse</label>
                <label class="option-label"><input type="radio" name="q56" value="D"> D) avesse pubblicato</label>
            </div>
        </div>

        <div class="question-card">
            <p><strong>57. Scegli l'opzione corretta con i pronomi combinati: "Hai dato il passaporto al delegato? Sì, ___________ ho dato stamattina."</strong></p>
            <div class="options">
                <label class="option-label"><input type="radio" name="q57" value="A"> A) lo gli</label>
                <label class="option-label"><input type="radio" name="q57" value="B"> B) glielo</label>
                <label class="option-label"><input type="radio" name="q57" value="C"> C) mela</label>
                <label class="option-label"><input type="radio" name="q57" value="D"> D) la gli</label>
            </div>
        </div>

        <button type="button" class="btn-submit" onclick="calculateScore()">Invia il Test / Soumettre l'examen</button>
    </form>

    <div id="result">
        <h2>Risultato del tuo Test</h2>
        <p id="score-text" style="font-size: 20px; font-weight: bold;"></p>
        <p id="evaluation-text"></p>
    </div>
</div>

<script>
    // Configurazione del timer: 72 minuti
    let totalTime = 72 * 60;
    const timerElement = document.getElementById('time');

    const countdown = setInterval(() => {
        let minutes = Math.floor(totalTime / 60);
        let seconds = totalTime % 60;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        timerElement.textContent = `${minutes}:${seconds}`;
        
        if (totalTime <= 0) {
            clearInterval(countdown);
            alert("Tempo scaduto! Il test verrà inviato automaticamente.");
            calculateScore();
        }
        totalTime--;
    }, 1000);

    // Risposte corrette del simulatore campione
    const correctAnswers = {
        q1: "B",
        q2: "B",
        q31: "B",
        q56: "B",
        q57: "B"
    };

    function calculateScore() {
        clearInterval(countdown);
        let score = 0;
        let correctCount = 0;
        let wrongCount = 0;
        let emptyCount = 0;

        // On boucle sur les clés des réponses configurate
        for (let key in correctAnswers) {
            const rbs = document.getElementsByName(key);
            let selectedValue = null;
            for (const rb of rbs) {
                if (rb.checked) {
                    selectedValue = rb.value;
                    break;
                }
            }

            if (selectedValue === null) {
                emptyCount++;
            } else if (selectedValue === correctAnswers[key]) {
                score += 1;
                correctCount++;
            } else {
                score -= 0.25;
                wrongCount++;
            }
        }

        // Ajustement proportionnel du score sur une base réelle de 72 questions
        // pour la simulation simplifiée fournie dans ce script
        let finalScore = (score / Object.keys(correctAnswers).length) * 72;
        finalScore = Math.max(0, finalScore).toFixed(2);

        document.getElementById('quiz-form').style.display = 'none';
        const resultDiv = document.getElementById('result');
        resultDiv.style.display = 'block';
        
        document.getElementById('score-text').textContent = `Punteggio stimato: ${finalScore} / 72`;
        
        let evalText = "";
        if (finalScore >= 55) {
            evalText = "Idoneo (Livello B2 Eccellente). Sei pronto per i corsi a Tor Vergata!";
        } else if (finalScore >= 40) {
            evalText = "Livello B1 superato, ma si consiglia di rinforzare le strutture per raggiungere il B2 richiesto.";
        } else {
            evalText = "Livello Insufficiente. Rivedi urgentemente la grammatica (Congiuntivo) e la comprensione scritta.";
        }
        document.getElementById('evaluation-text').textContent = evalText;
        window.scrollTo(0, document.body.scrollHeight);
    }
</script>

</body>
</html>
